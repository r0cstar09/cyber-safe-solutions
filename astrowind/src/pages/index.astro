---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Contact from '~/components/widgets/Contact.astro';

const metadata = {
  title: 'Cyber Safe Solutions - GoHighLevel Automation Agency',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Book a Free Strategy Call',
        href: '#contact',
        icon: 'tabler:calendar',
      },
      { text: 'View Services', href: '#services' },
    ]}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white">Automate Your Business</span> with GoHighLevel
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Cyber Safe Solutions</span> streamlines your operations with professional GoHighLevel automation.
      Stop losing leads and start converting with systems that work 24/7.
    </Fragment>
  </Hero>

  <!-- Services Section *************** -->

  <Features
    id="services"
    tagline="Services"
    title="Complete GoHighLevel Automation Solutions"
    subtitle="We build systems that capture leads, nurture relationships, and drive revenue while you focus on growth."
    items={[
      {
        title: 'CRM Setup & Configuration',
        description:
          'Custom GoHighLevel CRM tailored to your business processes. Organize contacts, track interactions, and manage your pipeline efficiently.',
        icon: 'tabler:database',
      },
      {
        title: 'Missed-Call Text Back',
        description:
          'Never miss an opportunity. Automatically text prospects when you miss their call, keeping engagement high and conversion rates strong.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Appointment Booking Automation',
        description:
          'Streamline scheduling with automated booking systems. Let clients book appointments 24/7 without manual coordination.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Lead Follow-Up Sequences',
        description:
          'Automated follow-up campaigns that nurture leads through your funnel. Turn cold prospects into warm clients systematically.',
        icon: 'tabler:target',
      },
      {
        title: 'Reactivation Campaigns',
        description:
          'Re-engage dormant clients with strategic automated campaigns. Recover lost revenue from your existing database.',
        icon: 'tabler:refresh',
      },
      {
        title: 'AI Chat Automation',
        description:
          'Intelligent chatbot integration that answers questions, qualifies leads, and books appointments automatically.',
        icon: 'tabler:robot',
      },
    ]}
  />

  <!-- Process Section **************** -->

  <Steps
    id="process"
    title="Our Process: From Strategy to Implementation"
    subtitle="We take a systematic approach to implementing automation that delivers results."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Discovery & Strategy</span>',
        description:
          'We analyze your current processes, identify gaps, and design a custom automation strategy aligned with your business goals.',
        icon: 'tabler:search',
      },
      {
        title: 'Step 2: <span class="font-medium">System Configuration</span>',
        description:
          'We build and configure your GoHighLevel system, including workflows, templates, and integrations tailored to your needs.',
        icon: 'tabler:settings',
      },
      {
        title: 'Step 3: <span class="font-medium">Testing & Optimization</span>',
        description:
          'We rigorously test every automation to ensure smooth operation, then optimize for maximum performance and conversion.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Step 4: <span class="font-medium">Launch & Support</span>',
        description:
          'Your systems go live with full documentation and training. We provide ongoing support to ensure continued success.',
        icon: 'tabler:rocket',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Steps>

  <!-- FAQ Section ******************** -->

  <FAQs
    id="faq"
    title="Frequently Asked Questions"
    subtitle="Get answers to common questions about our GoHighLevel automation services."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'What is GoHighLevel and why do I need it?',
        description:
          'GoHighLevel is an all-in-one CRM and marketing automation platform. It consolidates your tools into one system, reducing costs while improving lead capture, follow-up, and conversion rates.',
      },
      {
        title: 'How long does implementation take?',
        description:
          'Most implementations are completed within 2-4 weeks, depending on complexity. We start with core automations and expand from there, so you see results quickly.',
      },
      {
        title: 'Do you provide training and support?',
        description:
          'Yes. Every client receives comprehensive training documentation and video walkthroughs. We also offer ongoing support to ensure your team can manage and optimize the system.',
      },
      {
        title: 'Can you integrate with my existing tools?',
        description:
          'GoHighLevel integrates with most major platforms including Stripe, PayPal, Zapier, Calendly, and more. We handle all integration setup as part of our service.',
      },
      {
        title: 'What results can I expect?',
        description:
          'Clients typically see improved response times, higher booking rates, better lead nurturing, and recovered revenue from reactivation campaigns. Exact results depend on your business and implementation.',
      },
      {
        title: 'What if I need changes or updates later?',
        description:
          'We provide ongoing support packages for clients who need adjustments, new campaigns, or system expansions. You can also manage simple updates yourself with our training.',
      },
    ]}
  />

  <!-- Contact Section **************** -->

  <Contact
    id="contact"
    title="Ready to Automate Your Business?"
    subtitle="Book a free strategy call to discuss how GoHighLevel automation can transform your operations."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
      {
        type: 'tel',
        name: 'phone',
        label: 'Phone',
      },
    ]}
    textarea={{
      label: 'Tell us about your business and automation needs',
      name: 'message',
      rows: 4,
    }}
    disclaimer={{
      label:
        'By submitting this form, you agree to our Terms of Service and Privacy Policy. We will contact you within 24 hours.',
    }}
    description="We respond to all inquiries within 24 hours. Book your free strategy call and discover how automation can grow your business."
  />

  <!-- Final CTA Section ************** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book Your Free Strategy Call',
        href: '#contact',
        icon: 'tabler:calendar',
      },
    ]}
  >
    <Fragment slot="title">
      Stop Losing Leads.<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"
        >Start Converting with Automation.</span
      >
    </Fragment>

    <Fragment slot="subtitle">
      Join businesses already using GoHighLevel automation to capture more leads, close more deals, and scale
      efficiently.
    </Fragment>
  </CallToAction>
</Layout>
