---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Thank You - Cyber Safe Solutions',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
    <div class="text-center">
      <h1 class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 font-heading">
        Thank You! 🎉
      </h1>
      <p class="text-xl text-muted dark:text-slate-400 mb-8">
        We've received your message and will get back to you within 24 hours.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="btn btn-primary"
        >
          Return to Home
        </a>
        <a
          href="https://calendly.com/johnstonejoe395/30min"
          target="_blank"
          rel="noopener"
          class="btn btn-secondary"
        >
          Book a Strategy Call Now
        </a>
      </div>
    </div>
  </section>
</Layout>
